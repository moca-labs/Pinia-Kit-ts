{
  "name": "@moca-labs/pinia-kit-ts",
  "version": "0.4.1",
  "description": "TypeScript Pinia Store 관리 Kit - 스토어 정의 및 매니저",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "pinia",
    "vue",
    "store",
    "moca-labs"
  ],
  "author": "IDEa Team",
  "license": "Apache-2.0",
  "peerDependencies": {
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moca-labs/pinia-kit-ts.git"
  }
}
